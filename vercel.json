{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_API_URL": "/api/v1"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://sierlab-inventory-backend.onrender.com/api/v1/:path*"
    },
    {
      "source": "/api/v1/:path*/",
      "destination": "https://sierlab-inventory-backend.onrender.com/api/v1/:path*/"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://sierlab-inventory-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/uploads/:path*/",
      "destination": "https://sierlab-inventory-backend.onrender.com/uploads/:path*/"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
