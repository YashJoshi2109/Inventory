# ─── SIER Lab Inventory — Environment Template ────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
APP_NAME="SIER Lab Inventory"
APP_VERSION=1.0.0

# ── Database (Supabase / any cloud PostgreSQL) ────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Database → Connection Info
POSTGRES_HOST=db.<project-ref>.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-supabase-db-password>
DATABASE_SSL=true               # Always true for Supabase, Neon, etc.

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_256_BIT_RANDOM_HEX_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
BARCODE_DIR=./uploads/barcodes
MAX_UPLOAD_SIZE_MB=50

# ── AI Features ────────────────────────────────────────────────────────────────
AI_ANOMALY_DETECTION_ENABLED=true
AI_FORECAST_ENABLED=true
OPENAI_API_KEY=                  # Optional: for embedding-based NLP search (Phase 2)

# ── MQTT (domain events — analytics, ERP, IoT subscribers) ────────────────────
# EMQX Cloud Serverless example (TLS 8883). Use App ID + App Secret from console.
MQTT_ENABLED=false
MQTT_BROKER_HOST=your-cluster.REGION.emqxsl.com
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
MQTT_TOPIC_PREFIX=searlab/inventory
MQTT_USERNAME=your_emqx_app_id
MQTT_PASSWORD=your_emqx_app_secret
# Quote password if it contains ! * # etc.: MQTT_PASSWORD="your!secret"
MQTT_CLIENT_ID=
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_KEEPALIVE=60
MQTT_MAX_INFLIGHT=100
# Optional: custom CA / client certs (cloud brokers usually use system CAs)
MQTT_TLS_CA_PATH=
MQTT_TLS_CERT_PATH=
MQTT_TLS_KEY_PATH=
MQTT_TLS_INSECURE=false
# Docker: docker compose --profile mqtt up — then set MQTT_BROKER_HOST=mqtt

# ── Email Alerts (optional) ────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
# Brevo (HTTPS API; good on Render/Vercel). Free tier ~300 emails/day — see https://developers.brevo.com/docs/getting-started
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=SEAR Lab Inventory
BREVO_FREE_TIER_DAILY_LIMIT=300
# Resend (optional fallback if Brevo not set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=/api/v1
