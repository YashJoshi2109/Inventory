# ─── SIER Lab Inventory — Environment Template ────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
APP_NAME="SIER Lab Inventory"
APP_VERSION=1.0.0

# ── Database (Supabase / any cloud PostgreSQL) ────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Database → Connection Info
POSTGRES_HOST=db.<project-ref>.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-supabase-db-password>
DATABASE_SSL=true               # Always true for Supabase, Neon, etc.

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_256_BIT_RANDOM_HEX_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
BARCODE_DIR=./uploads/barcodes
MAX_UPLOAD_SIZE_MB=50

# ── AI Features ────────────────────────────────────────────────────────────────
AI_ANOMALY_DETECTION_ENABLED=true
AI_FORECAST_ENABLED=true
OPENAI_API_KEY=                  # Optional: for embedding-based NLP search (Phase 2)

# ── MQTT (Phase 2 — set to true to activate) ─────────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=sierlab/inventory

# ── Email Alerts (optional) ────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=/api/v1
